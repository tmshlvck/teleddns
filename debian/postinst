#!/bin/sh
set -e

#DEBHELPER#

# Create config directory
mkdir -p /etc/teleddns

# Lock down the state directory (persisted push state; see PRD.md M3)
if [ -d /var/lib/teleddns ]; then
    chmod 0750 /var/lib/teleddns
fi

# Inform user about sample configuration
if [ ! -f /etc/teleddns/teleddns.yaml ]; then
    echo "TeleDDNS installed. To configure:"
    echo "  cp /usr/share/doc/teleddns/teleddns.yaml.sample /etc/teleddns/teleddns.yaml"
    echo "  # Edit /etc/teleddns/teleddns.yaml with your DDNS credentials"
    echo "  systemctl daemon-reload"
    echo "  systemctl enable --now teleddns"
fi
